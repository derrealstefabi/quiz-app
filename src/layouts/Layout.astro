---
import { AmplifyClientConfig } from "../components/AmplifyClientConfig";
import { AwsLoginButton } from "../components/AwsLoginButton";
import "../styles/global.css";
import cat from "../assets/animal.png"
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Quiz App</title>
	</head>
	<body>
		<AmplifyClientConfig client:only="react" />
		<div id="header" class="relative top-0 flex p-5">
			<a href={import.meta.env.BASE_URL}>
				<img src={cat.src} alt="logo" class="w-12 h-12">
			</a>
			<div class="ms-auto">
				<AwsLoginButton client:only="react"></AwsLoginButton>
			</div>
		</div>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		background: #94B9FF;
		background: linear-gradient(90deg,rgba(148, 185, 255, 1) 0%, rgba(229, 149, 252, 1) 100%) no-repeat center / 100% 100%;;
	}
</style>